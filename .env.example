# --- Database ---
DATABASE_URL=postgresql+psycopg2://worktube:worktube@localhost:5432/worktube

# --- SAM.gov ---
# Get a key at https://open.gsa.gov/api/get-opportunities-public-api/
SAM_API_KEY=
SAM_BASE_URL=https://api.sam.gov/opportunities/v2/search

# --- UNGM ---
UNGM_BASE_URL=https://www.ungm.org/Public/Notice/Search

# --- Ingestion ---
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
INGEST_LOOKBACK_DAYS=7

# --- Scoring ---
# Final = DESIGN_WEIGHT * design_fit + SECTOR_WEIGHT * sector_fit
DESIGN_WEIGHT=0.6
SECTOR_WEIGHT=0.4
# Opportunities at/above this are "high fit" (digest threshold)
HIGH_FIT_THRESHOLD=70
