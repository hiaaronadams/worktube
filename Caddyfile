# Caddy reverse proxy.
#
# DOMAIN controls TLS:
#   - a real domain (rfp.example.com) -> automatic HTTPS via Let's Encrypt
#   - ":80"                           -> plain HTTP (use when hitting the VPS by IP)
#
# Everything under /api/* is proxied to the backend (prefix stripped, so the
# API still sees /opportunities, /health, ...). Everything else goes to the
# Next.js frontend. Because the API is same-origin, no CORS is involved.

{$DOMAIN:":80"} {
	handle_path /api/* {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
