# Production deploy config — copy to .env.prod and fill in.
# Used by: docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# --- Domain / TLS ---
# Real domain pointed at this VPS -> automatic HTTPS:
#   DOMAIN=rfp.yourstudio.com
# Or hit the server by IP over plain HTTP (no domain yet):
#   DOMAIN=:80
DOMAIN=:80

# --- Database ---
POSTGRES_USER=worktube
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=worktube

# --- SAM.gov ingestion (optional but needed for live US federal data) ---
SAM_API_KEY=

# --- CORS ---
# Only needed if you serve the API on a DIFFERENT origin than the frontend.
# With the default Caddy same-origin /api setup you can leave this as-is.
CORS_ORIGINS=http://localhost:3000
